# Core app
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret

# Protected admin ingestion
ADMIN_INGEST_SECRET=replace-with-a-long-random-secret

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# S3-compatible document storage. Neon stores metadata only; files live here.
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=eu-west-1
S3_BUCKET=atlas-insight-documents
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# Stripe subscription scaffold
STRIPE_PUBLIC_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me

# Optional AI support layer. AI may summarize/extract only from sourced data.
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_MOCK_MODE=false

# Optional provider/data feeds.
# Free/no-key defaults can be written to .env.local with:
#   npm run providers:defaults
#   npm run providers:check
#
# Do not use CIA Factbook as live intelligence. If configured, treat as historical/reference only.
CIA_FACTBOOK_SOURCE_URL=

# Free/public/official, no key required. Safe defaults:
UK_FCDO_API_URL=https://www.gov.uk/api/search.json?filter_format=travel_advice&count=100
AU_SMARTRAVELLER_API_URL=https://www.smartraveller.gov.au/rss
DISASTER_FEED_URL=https://www.gdacs.org/xml/rss.xml
USGS_EARTHQUAKE_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/significant_month.geojson
HEALTH_OUTBREAK_FEED_URL=https://wwwnc.cdc.gov/travel/rss/notices.xml
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc?query=travel%20OR%20protest%20OR%20airport%20OR%20security&mode=ArtList&format=json&maxrecords=50&sort=HybridRel
NEWS_RSS_FEEDS=https://www.smartraveller.gov.au/rss,https://www.gdacs.org/xml/rss.xml,https://wwwnc.cdc.gov/travel/rss/notices.xml

# Manual/official-page extraction or adapter extension required before defaulting.
US_STATE_ADVISORY_API_URL=
CANADA_ADVISORY_API_URL=
NZ_MFAT_ADVISORY_API_URL=
OFFICIAL_PAGE_URLS=

# Paid/optional or provider-specific keys.
AVIATIONSTACK_API_KEY=
WEATHER_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
