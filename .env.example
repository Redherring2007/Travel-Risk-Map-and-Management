# Core app
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret

# Protected admin ingestion
ADMIN_INGEST_SECRET=replace-with-a-long-random-secret

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# S3-compatible document storage. Neon stores metadata only; files live here.
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=eu-west-1
S3_BUCKET=atlas-insight-documents
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# Stripe subscription scaffold
STRIPE_PUBLIC_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me

# Optional AI support layer. AI may summarize/extract only from sourced data.
# Default local mode uses Ollama. OpenAI remains available by setting AI_PROVIDER=openai.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TRAVEL_MODEL=atlas-travel-risk:latest
AI_MODEL=atlas-travel-risk:latest
AI_SCOUT_MODEL=atlas-travel-risk-scout:latest
AI_ANALYST_MODEL=atlas-travel-risk-analyst:latest
AI_REPORT_MODEL=atlas-travel-risk:latest
AI_ROUTE_MODEL=atlas-travel-risk-route:latest
AI_HOTEL_MODEL=atlas-travel-risk-hotels:latest
AI_MATRIX_MODEL=atlas-risk-matrix:latest
AI_MOCK_MODE=false
OPENAI_API_KEY=
AI_API_KEY=

# Optional provider/data feeds. Empty values keep labelled demo fallback active.
CIA_FACTBOOK_SOURCE_URL=
UK_FCDO_API_URL=
US_STATE_ADVISORY_API_URL=
CANADA_ADVISORY_API_URL=
AU_SMARTRAVELLER_API_URL=
NZ_MFAT_ADVISORY_API_URL=
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
NEWS_RSS_FEEDS=
DISASTER_FEED_URL=
USGS_EARTHQUAKE_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/significant_month.geojson
HEALTH_OUTBREAK_FEED_URL=
AVIATIONSTACK_API_KEY=
WEATHER_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
OFFICIAL_PAGE_URLS=
OSM_USER_AGENT=AtlasInsightTravelRisk/0.1 contact=admin@example.com
